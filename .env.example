# =============================================================================
# Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control
# =============================================================================

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Your App Name

# -----------------------------------------------------------------------------
# Database (if using better-auth with database)
# -----------------------------------------------------------------------------
# For SQLite (development)
# DATABASE_URL=file:./dev.db

# For PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# For MySQL (production)
# DATABASE_URL=mysql://user:password@localhost:3306/dbname

# -----------------------------------------------------------------------------
# WasenderAPI - OTP SMS Service
# -----------------------------------------------------------------------------
# Get your API key from https://wasenderapi.com
WASENDER_API_KEY=your_wasender_api_key_here

# -----------------------------------------------------------------------------
# Better Auth (if using)
# -----------------------------------------------------------------------------
# Better Auth requires a secret key
BETTER_AUTH_SECRET=your_random_secret_key_min_32_characters

# Better Auth URL (usually same as app URL in production)
BETTER_AUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Authentication Providers (optional)
# -----------------------------------------------------------------------------

# Google OAuth
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# Apple OAuth
# APPLE_CLIENT_ID=your_apple_client_id
# APPLE_CLIENT_SECRET=your_apple_client_secret
# APPLE_TEAM_ID=your_apple_team_id
# APPLE_KEY_ID=your_apple_key_id

# GitHub OAuth
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret

# -----------------------------------------------------------------------------
# Email Service (for transactional emails)
# -----------------------------------------------------------------------------
# SMTP Configuration
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_smtp_username
# SMTP_PASSWORD=your_smtp_password
# SMTP_FROM=noreply@yourdomain.com

# Resend (alternative email service)
# RESEND_API_KEY=your_resend_api_key

# -----------------------------------------------------------------------------
# Payment Gateways (optional)
# -----------------------------------------------------------------------------

# Stripe
# STRIPE_PUBLIC_KEY=pk_test_xxx
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# Razorpay (India)
# RAZORPAY_KEY_ID=your_razorpay_key_id
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------

# Cloud Storage (for file uploads)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your_bucket_name

# Or use Vercel Blob
# BLOB_READ_WRITE_TOKEN=your_vercel_blob_token

# -----------------------------------------------------------------------------
# Analytics (optional)
# -----------------------------------------------------------------------------
# Google Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Vercel Analytics
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your_analytics_id

# -----------------------------------------------------------------------------
# Development Settings
# -----------------------------------------------------------------------------
NODE_ENV=development

# Debug mode (shows more detailed errors)
# NEXT_PUBLIC_DEBUG=false
